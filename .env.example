# Port the server listens on (Railway sets this automatically)
PORT=3001

# The public Railway URL for this service.
# After deploying, set this in your n8n HTTP Request node as the webhook URL.
# Format: https://your-service-name.up.railway.app/api/n8n-webhook/log
DASHBOARD_WEBHOOK_URL=https://your-service.up.railway.app/api/n8n-webhook/log
